# Path SQLite (relatif ke folder prisma/). Di Docker di-override ke volume, mis. file:/data/dev.db
DATABASE_URL="file:./dev.db"

# Secret untuk menandatangani JWT. WAJIB diganti di produksi.
JWT_SECRET="dev-secret-change-me"

# Token bot Telegram dari @BotFather. Kosongkan untuk menjalankan API tanpa bot.
BOT_TOKEN=""

# URL publik (HTTPS) tempat mini app di-host, mis. https://app.deedims.com/app/.
# Dipakai untuk Menu Button + tombol web_app bot. Kosongkan untuk menonaktifkan launch mini app.
# Saat BOT_TOKEN kosong (dev), endpoint /api/miniapp/auth menerima { devUserId } tanpa validasi initData.
MINI_APP_URL=""

# Port HTTP API (3000 default; pakai 3100 kalau 3000 sudah terpakai layanan lain)
PORT=3100

# Timezone aplikasi. Data tetap disimpan UTC di DB; ini hanya untuk penjadwalan & format tampilan.
TZ="Asia/Jakarta"

# Retensi bot_messages (hari). Cron harian menghapus baris lebih tua dari nilai ini.
RETENTION_DAYS=14

# Origin frontend yang diizinkan CORS (dev Vite)
CORS_ORIGIN="http://localhost:5173"

# Folder penyimpanan foto menu (hosting lokal). Di Docker di-override ke volume, mis. /data/uploads
UPLOADS_DIR="./uploads"

# Batas ukuran upload (MB)
MAX_UPLOAD_MB=5
